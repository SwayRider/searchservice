# searchservice environment configuration

# Server ports
HTTP_PORT=8080
GRPC_PORT=8081

# Pelias geocoding servers
# Format: comma-separated region=base-url pairs
# The region names must match values returned by RegionService
PELIAS_REGIONS=iberian-peninsula=http://192.168.1.222:33111/v1,west-europe=http://192.168.1.222:33121/v1

# RegionService connection
REGIONSERVICE_HOST=192.168.1.222
REGIONSERVICE_PORT=34103

# AuthService connection (for JWT public key retrieval)
AUTHSERVICE_HOST=192.168.1.222
AUTHSERVICE_PORT=34101
