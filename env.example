########################################
# Service ports and urls               #
########################################
#
# Most of these can be kept as is.
# You probably only need to change these ports if you run multiple
# services simultaneously on your local dev machine.
#

HTTP_PORT=8080

GRPC_PORT=8081

########################################
# Pelias geocoding servers             #
########################################
#
# Format: comma-separated region=base-url pairs
# The region names must match values returned by RegionService
#
# Example format:
# PELIAS_REGIONS=iberian-peninsula=http://192.168.1.222:33111/v1,west-europe=http://192.168.1.222:33121/v1
#

PELIAS_REGIONS=iberian-peninsula=http://192.168.1.222:33111/v1,west-europe=http://192.168.1.222:33121/v1

########################################
# RegionService connection           #
########################################
#
# Connection details to the RegionService
# Used for retrieving region information
#

REGIONSERVICE_HOST=192.168.1.222
REGIONSERVICE_PORT=34103

########################################
# AuthService connection              #
########################################
#
# Connection details to the AuthService
# Used for JWT public key retrieval
#

AUTHSERVICE_HOST=192.168.1.222
AUTHSERVICE_PORT=34101